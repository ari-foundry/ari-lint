mod cli;
mod severity;
mod diagnostic;
mod output;
mod rule;
mod registry;
mod rules;
mod config;
mod source;
mod lint;
mod parity;

fn run_main_entry_shell() -> i64 {
  zone(65536) {
    let result = cli::run_os_argv_cli_with_main_output();
    return result.exit_code.code;
  }
}

fn main() -> i64 {
  return run_main_entry_shell();
}
