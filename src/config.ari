// Config data shapes only. This file does not parse ari-lint.rules or CLI input.

pub enum ConfigSource {
  AriLintRulesFile,
  CommandLine,
}

pub struct RuleSeverityOverride {
  rule_code: String,
  severity: super::severity::Severity,
  source: ConfigSource,
}

pub struct ConfigSkeleton {
  source: ConfigSource,
  override_entry: RuleSeverityOverride,
}
