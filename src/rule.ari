// Rule metadata shapes only. This file does not execute lint rules.

pub enum RuleSeverity {
  Off,
  Hint,
  Note,
  Warning,
  Error,
}

pub struct RuleDescriptor {
  code: String,
  short_name: String,
  default_severity: RuleSeverity,
  description: String,
}

// Future descriptors may cover lint/trailing-whitespace and
// lint/missing-final-newline, but this file does not implement either rule.
